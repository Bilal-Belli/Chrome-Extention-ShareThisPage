{
    "manifest_version": 3,
    "name": "Share This Page Pro",
    "version": "1.0.0",
    "description": "Share any web page across 100+ platforms instantly",
    "permissions": [
        "activeTab",
        "clipboardWrite",
        "storage",
        "sidePanel"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "action": {
        "default_title": "Share This Page Pro",
        "default_popup": "panel.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "panel.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}